# Coulisse Heir SEO Agent v3 — Environment Variables
# Copy to .env and fill in your values

# ── Anthropic (required) ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Brand / Site (required) ───────────────────────────────────────────────────
BRAND=coulissehair
SITE_URL=https://coulisseheir.com/

# ── Google Search Console (required) ─────────────────────────────────────────
GSC_CREDENTIALS_PATH=config/gsc_credentials.json

# ── WordPress (required) ─────────────────────────────────────────────────────
WP_URL=https://coulisseheir.com
WP_USERNAME=ad_chadmin
# WP Admin (https://coulisseheir.com/chsysadmin) → Users → Your Profile → Application Passwords → Add New
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# ── Email Notifications (required — approval emails sent here) ────────────────
# Gmail account used to SEND the approval email
GMAIL_USER=your_gmail@gmail.com
# Gmail → Manage your Google Account → Security → App Passwords → Generate
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Email address(es) to RECEIVE the approval email (comma-separated for multiple)
NOTIFICATION_EMAIL=your_email@example.com

# ── Featured Images (optional but recommended) ────────────────────────────────
# Get free API key at https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# ── Google Business Profile (optional — for GBP auto-posting) ────────────────
GBP_ACCOUNT_NAME=accounts/XXXXXXXXXX
GBP_LOCATION_ID_JURONG=locations/XXXXXXXXXX
GBP_LOCATION_ID_PASIRRIS=locations/XXXXXXXXXX
GBP_LOCATION_ID_BISHAN=locations/XXXXXXXXXX
